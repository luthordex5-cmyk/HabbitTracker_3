        JPanel top = new JPanel();
        top.setLayout(new BoxLayout(top,BoxLayout.Y_AXIS));

        JButton addBtn = new JButton("+ Add New Habit");
        addBtn.setAlignmentX(Component.CENTER_ALIGNMENT);
        addBtn.addActionListener(e->addNewHabit());

        habitListContainer = new JPanel();
        habitListContainer.setLayout(new BoxLayout(habitListContainer,BoxLayout.Y_AXIS));

        JScrollPane scroll =
                new JScrollPane(habitListContainer);

        scroll.setPreferredSize(new Dimension(450,300));
        scroll.setBorder(BorderFactory.createTitledBorder("Daily Progress"));

        top.add(addBtn);
        top.add(Box.createRigidArea(new Dimension(0,10)));
        top.add(scroll);


        JPanel controls = new JPanel(new FlowLayout());

        habitSelector = new JComboBox<>();

        updateBtn = new JButton("Update");
        deleteBtn = new JButton("Delete");

        JButton historyBtn = new JButton("History");
        JButton achieveBtn = new JButton("Achievements");

        updateBtn.addActionListener(e->updateHabit());
        deleteBtn.addActionListener(e->deleteHabit());

        historyBtn.addActionListener(
                e->new CompletedHabitsFrame(habits).setVisible(true));

        achieveBtn.addActionListener(
                e->new AchievementFrame(habits).setVisible(true));

        controls.add(new JLabel("Select:"));
        controls.add(habitSelector);
        controls.add(updateBtn);
        controls.add(deleteBtn);
        controls.add(historyBtn);
        controls.add(achieveBtn);


        statusLabel = new JLabel("Status: Ready");

        main.add(top,BorderLayout.CENTER);
        main.add(controls,BorderLayout.NORTH);
        main.add(statusLabel,BorderLayout.SOUTH);
    }



    private void refreshUI(){

        habitListContainer.removeAll();
        habitSelector.removeAllItems();

        boolean any=false;

        for(Habit h:habits){

            habitSelector.addItem(h.getName());

            if(!h.isGoalReached()){

                any=true;

                JPanel row = new JPanel(new BorderLayout(10,0));
                row.setMaximumSize(new Dimension(450,70));

                JButton log = new JButton("Log: "+h.getName());

                log.addActionListener(e->{

                    h.addCompletion();

                    if(h.isGoalReached()){
                        JOptionPane.showMessageDialog(this,"🏆 Goal reached!");
                    }

                    refreshUI();
                });


                JProgressBar bar = new JProgressBar(0,h.getGoal());
                bar.setValue(h.getStreakCount());
                bar.setStringPainted(true);
                bar.setString(h.getStreakCount()+"/"+h.getGoal()+" Days");


                JPanel info = new JPanel();
                info.setLayout(new BoxLayout(info,BoxLayout.Y_AXIS));

                String last="No streak yet";

                if(!h.getCompletionDates().isEmpty()){
                    last = h.getCompletionDates()
                            .get(h.getCompletionDates().size()-1);
                }

                JLabel lastLog = new JLabel("Last Log: "+last);

                JButton viewHistory = new JButton("View History");

                viewHistory.addActionListener(e->{

                    StringBuilder sb = new StringBuilder();

                    for(String d : h.getCompletionDates()){
                        sb.append(d).append("\n");
                    }

                    if(sb.length()==0){
                        sb.append("No history yet.");
                    }

                    JTextArea area = new JTextArea(sb.toString());
                    area.setEditable(false);

                    JOptionPane.showMessageDialog(this,
                            new JScrollPane(area),
                            h.getName()+" History",
                            JOptionPane.INFORMATION_MESSAGE);
                });


                JLabel status = new JLabel("HABIT IN PROGRESS");

                info.add(lastLog);
                info.add(viewHistory);
                info.add(status);

                row.add(log,BorderLayout.WEST);
                row.add(bar,BorderLayout.CENTER);
                row.add(info,BorderLayout.EAST);

                habitListContainer.add(row);
            }
        }

        if(!any){
            habitListContainer.add(
                    new JLabel("No active habits. Click + to start one!"));
        }

        statusLabel.setText(
                "Active Habits: "+
                        habits.stream().filter(h->!h.isGoalReached()).count());

        revalidate();
        repaint();
        saveData();
    }



    private void addNewHabit(){

        String name = JOptionPane.showInputDialog(this,"Habit Name:");

        if(name==null || name.trim().isEmpty()) return;

        String goalStr = JOptionPane.showInputDialog(this,"Goal (Days):","7");

        try{

            int goal = Integer.parseInt(goalStr);

            habits.add(new Habit(name.trim(),goal));

            refreshUI();

        }catch(NumberFormatException e){

            JOptionPane.showMessageDialog(this,
                    "Enter a valid number.");
        }
    }



    private void updateHabit(){

        String selected = (String)habitSelector.getSelectedItem();

        if(selected==null) return;

        for(int i=0;i<habits.size();i++){

            if(habits.get(i).getName().equals(selected)){

                Habit old = habits.get(i);

                String newName =
                        JOptionPane.showInputDialog(this,"New Name:",old.getName());

                if(newName==null||newName.trim().isEmpty()) return;

                String goalStr =
                        JOptionPane.showInputDialog(this,"New Goal:",old.getGoal());

                try{

                    int goal = Integer.parseInt(goalStr);

                    Habit updated = new Habit(newName.trim(),goal);

                    updated.getCompletionDates()
                            .addAll(old.getCompletionDates());

                    habits.set(i,updated);

                    refreshUI();
                    return;

                }catch(NumberFormatException e){
                    JOptionPane.showMessageDialog(this,"Invalid number.");
                }
            }
        }
    }



    private void deleteHabit(){

        String selected = (String)habitSelector.getSelectedItem();

        if(selected!=null){
            habits.removeIf(h->h.getName().equals(selected));
            refreshUI();
        }
    }



    private void saveData(){

        try(ObjectOutputStream oos =
                    new ObjectOutputStream(new FileOutputStream(FILE_NAME))){

            oos.writeObject(habits);

        }catch(IOException e){
            e.printStackTrace();
        }
    }



    @SuppressWarnings("unchecked")
    private void loadData(){

        try(ObjectInputStream ois =
                    new ObjectInputStream(new FileInputStream(FILE_NAME))){

            habits = (List<Habit>)ois.readObject();

        }catch(Exception e){

            habits = new ArrayList<>();
        }
    }



    public static void main(String[] args){

        SwingUtilities.invokeLater(
                ()->new HabitTracker_3().setVisible(true));
    }
}





package HabitTracker_2;

import javax.swing.*;
import javax.swing.border.*;
import java.awt.*;
import java.io.*;
import java.time.LocalDateTime;
import java.time.format.DateTimeFormatter;
import java.util.ArrayList;
import java.util.List;

// --- Habit Data Class ---
class Habit implements Serializable {
    private static final long serialVersionUID = 1L;
    private String name;
    private int goal;
    private List<String> completionDates;

    public Habit(String name, int goal) {
        this.name = name;
        this.goal = goal;
        this.completionDates = new ArrayList<>();
    }

    public String getName() {
        return name;
    }

    public int getGoal() {
        return goal;
    }

    public List<String> getCompletionDates() {
        return completionDates;
    }

    public void addCompletion() {
        DateTimeFormatter formatter = DateTimeFormatter.ofPattern("yyyy-MM-dd (HH:mm:ss)");
        completionDates.add(LocalDateTime.now().format(formatter));
    }

    public int getStreakCount() {
        return completionDates.size();
    }

    public boolean isGoalReached() {
        return getStreakCount() >= goal;
    }
}

// --- Achievement Entry (persisted separately) ---
class AchievementEntry implements Serializable {
    private static final long serialVersionUID = 1L;
    private String habitName;
    private int goal;
    private String completedDateTime;

    public AchievementEntry(String habitName, int goal, String completedDateTime) {
        this.habitName = habitName;
        this.goal = goal;
        this.completedDateTime = completedDateTime;
    }

    public String getHabitName() {
        return habitName;
    }

    public int getGoal() {
        return goal;
    }

    public String getCompletedDateTime() {
        return completedDateTime;
    }
}

// --- Achievements Frame ---
class AchievementFrame extends JFrame {

    public AchievementFrame(List<AchievementEntry> achievements) {
        setTitle("Achievements");
        setSize(450, 500);
        setDefaultCloseOperation(JFrame.DISPOSE_ON_CLOSE);
        setLocationRelativeTo(null);

        JPanel root = new JPanel(new BorderLayout());
        root.setBackground(Color.WHITE);

        // Header
        JPanel header = new JPanel();
        header.setBackground(Color.WHITE);
        header.setBorder(BorderFactory.createEmptyBorder(15, 20, 5, 20));
        JLabel title = new JLabel("ACHIEVEMENTS");
        title.setFont(new Font("SansSerif", Font.BOLD, 20));
        title.setForeground(Color.BLACK);
        header.add(title);

        // Content
        JPanel contentPanel = new JPanel();
        contentPanel.setLayout(new BoxLayout(contentPanel, BoxLayout.Y_AXIS));
        contentPanel.setBackground(Color.WHITE);
        contentPanel.setBorder(BorderFactory.createEmptyBorder(10, 15, 15, 15));

        if (achievements == null || achievements.isEmpty()) {
            JLabel empty = new JLabel("No achievements yet. Complete a habit to earn one!");
            empty.setForeground(Color.BLACK);
            empty.setFont(new Font("SansSerif", Font.PLAIN, 13));
            empty.setAlignmentX(Component.CENTER_ALIGNMENT);
            contentPanel.add(Box.createRigidArea(new Dimension(0, 20)));
            contentPanel.add(empty);
        } else {
            int rank = 1;
            for (AchievementEntry entry : achievements) {
                JPanel card = buildCard(entry, rank++);
                contentPanel.add(card);
                contentPanel.add(Box.createRigidArea(new Dimension(0, 8)));
            }
        }

        JScrollPane scroll = new JScrollPane(contentPanel);
        scroll.setBorder(BorderFactory.createEmptyBorder());
        scroll.setBackground(Color.WHITE);
        scroll.getViewport().setBackground(Color.WHITE);

        root.add(header, BorderLayout.NORTH);
        root.add(scroll, BorderLayout.CENTER);
        setContentPane(root);
    }

    private JPanel buildCard(AchievementEntry entry, int rank) {
        JPanel card = new JPanel(new BorderLayout(10, 5));
        card.setBackground(Color.WHITE);
        card.setBorder(BorderFactory.createCompoundBorder(
                BorderFactory.createLineBorder(Color.BLACK, 1),
                BorderFactory.createEmptyBorder(10, 14, 10, 14)));
        card.setMaximumSize(new Dimension(Integer.MAX_VALUE, 75));

        // Rank label
        JLabel badge = new JLabel("#" + rank);
        badge.setFont(new Font("SansSerif", Font.BOLD, 16));
        badge.setForeground(Color.BLACK);
        badge.setPreferredSize(new Dimension(35, 40));
        badge.setHorizontalAlignment(SwingConstants.CENTER);

        // Info
        JPanel info = new JPanel();
        info.setOpaque(false);
        info.setLayout(new BoxLayout(info, BoxLayout.Y_AXIS));

        JLabel nameLabel = new JLabel(entry.getHabitName());
        nameLabel.setFont(new Font("SansSerif", Font.BOLD, 13));
        nameLabel.setForeground(Color.BLACK);

        JLabel detailLabel = new JLabel(
                "Goal: " + entry.getGoal() + " days  |  Completed: " + entry.getCompletedDateTime());
        detailLabel.setFont(new Font("SansSerif", Font.PLAIN, 11));
        detailLabel.setForeground(Color.BLACK);

        info.add(nameLabel);
        info.add(Box.createRigidArea(new Dimension(0, 4)));
        info.add(detailLabel);

        card.add(badge, BorderLayout.WEST);
        card.add(info, BorderLayout.CENTER);

        return card;
    }
}

// --- Frame for Completed Habits (History + Restart) ---
class CompletedHabitsFrame extends JFrame {
    public CompletedHabitsFrame(List<Habit> habits, HabitTracker mainApp) {
        setTitle("Completed Habits History");
        setSize(450, 400);
        setDefaultCloseOperation(JFrame.DISPOSE_ON_CLOSE);
        setLocationRelativeTo(null);

        JPanel contentPanel = new JPanel();
        contentPanel.setLayout(new BoxLayout(contentPanel, BoxLayout.Y_AXIS));
        contentPanel.setBorder(BorderFactory.createEmptyBorder(10, 10, 10, 10));

        boolean found = false;
        if (habits != null) {
            for (Habit h : habits) {
                if (h.isGoalReached()) {
                    found = true;
                    JPanel card = new JPanel(new BorderLayout(10, 5));
                    card.setBorder(BorderFactory.createTitledBorder(h.getName()));
                    card.setMaximumSize(new Dimension(420, 90));

                    String lastDate = h.getCompletionDates().isEmpty() ? "N/A"
                            : h.getCompletionDates().get(h.getCompletionDates().size() - 1);

                    JLabel details = new JLabel(
                            "<html>Goal: " + h.getGoal() + " days<br>Finished: " + lastDate + "</html>");

                    JButton restartBtn = new JButton("Restart");
                    restartBtn.addActionListener(e -> {
                        h.getCompletionDates().clear();
                        mainApp.refreshUI();
                        dispose();
                    });

                    card.add(details, BorderLayout.CENTER);
                    card.add(restartBtn, BorderLayout.EAST);
                    contentPanel.add(card);
                    contentPanel.add(Box.createRigidArea(new Dimension(0, 10)));
                }
            }
        }

        if (!found)
            contentPanel.add(new JLabel("No completed habits yet. Keep going!"));

        add(new JScrollPane(contentPanel));
    }
}

